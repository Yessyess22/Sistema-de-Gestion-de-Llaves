@model SistemaGestionLlaves.Models.Persona

@{
    ViewData["Title"] = "Editar Persona";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none d-inline-flex align-items-center gap-1 mb-2" style="color: #64748b; font-weight: 500; font-size: 0.9rem;">
        <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
    <h2 class="fw-bold" style="color:#0f172a; font-size:1.4rem;">
        <i class="bi bi-pencil-square me-2" style="color:#0369a1;"></i>Editar Persona
    </h2>
    <p style="color:#64748b; font-size:0.875rem;">Actualiza la información de <strong>@Model.Nombres @Model.Apellidos</strong>.</p>
</div>

<div class="ui-card" style="max-width: 800px;">
    <form asp-action="Edit">
        <!-- ID oculto -->
        <input type="hidden" asp-for="IdPersona" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Nombres" class="form-label fw-semibold" style="color: #334155; font-size: 0.9rem;"></label>
                <input asp-for="Nombres" class="form-control" style="border-radius: 10px; padding: 10px;" />
                <span asp-validation-for="Nombres" class="text-danger" style="font-size: 0.8rem;"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Apellidos" class="form-label fw-semibold" style="color: #334155; font-size: 0.9rem;"></label>
                <input asp-for="Apellidos" class="form-control" style="border-radius: 10px; padding: 10px;" />
                <span asp-validation-for="Apellidos" class="text-danger" style="font-size: 0.8rem;"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="Ci" class="form-label fw-semibold" style="color: #334155; font-size: 0.9rem;"></label>
                <input asp-for="Ci" class="form-control" style="border-radius: 10px; padding: 10px;" />
                <span asp-validation-for="Ci" class="text-danger" style="font-size: 0.8rem;"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="FechaNacimiento" class="form-label fw-semibold" style="color: #334155; font-size: 0.9rem;"></label>
                <input asp-for="FechaNacimiento" type="date" class="form-control" style="border-radius: 10px; padding: 10px;" />
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Genero" class="form-label fw-semibold" style="color: #334155; font-size: 0.9rem;"></label>
                <select asp-for="Genero" class="form-select" style="border-radius: 10px; padding: 10px;">
                    <option value="">-- Seleccione --</option>
                    <option value="M">Masculino</option>
                    <option value="F">Femenino</option>
                    <option value="O">Otro</option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Correo" class="form-label fw-semibold" style="color: #334155; font-size: 0.9rem;"></label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0" style="border-radius: 10px 0 0 10px; color: #94a3b8;">
                        <i class="bi bi-envelope"></i>
                    </span>
                    <input asp-for="Correo" type="email" class="form-control border-start-0" 
                           style="border-radius: 0 10px 10px 0; padding: 10px;" />
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Celular" class="form-label fw-semibold" style="color: #334155; font-size: 0.9rem;"></label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0" style="border-radius: 10px 0 0 10px; color: #94a3b8;">
                        <i class="bi bi-phone"></i>
                    </span>
                    <input asp-for="Celular" class="form-control border-start-0" 
                           style="border-radius: 0 10px 10px 0; padding: 10px;" />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="Estado" class="form-label fw-semibold" style="color: #334155; font-size: 0.9rem;"></label>
                <select asp-for="Estado" class="form-select" style="border-radius: 10px; padding: 10px;">
                    <option value="A">Activo</option>
                    <option value="I">Inactivo</option>
                </select>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top d-flex gap-2">
            <button type="submit" class="btn px-4 py-2" 
                    style="background:#0369a1; border-color:#0369a1; color:white; border-radius:10px; font-weight:600;">
                <i class="bi bi-arrow-repeat me-2"></i>Actualizar Datos
            </button>
            <a asp-action="Index" class="btn px-4 py-2" 
               style="background:#f1f5f9; color:#475569; border:none; border-radius:10px; font-weight:600;">
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
