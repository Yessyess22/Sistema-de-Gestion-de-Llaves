@model SistemaGestionLlaves.Models.Persona

@{
    ViewData["Title"] = "Detalle de Persona";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold" style="color:#0f172a; font-size:1.4rem; margin-bottom:2px;">
            <i class="bi bi-person-lines-fill me-2" style="color:#0369a1;"></i>Detalle de Persona
        </h2>
        <p class="mb-0" style="color:#64748b; font-size:0.875rem;">Información completa de la persona seleccionada.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.IdPersona" class="btn d-flex align-items-center gap-2 px-4 py-2"
           style="background:#e0f2fe; color:#0369a1; border-radius:12px; font-weight:600; border:none;">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <a asp-action="Index" class="btn d-flex align-items-center gap-2 px-4 py-2"
           style="background:#f1f5f9; color:#64748b; border-radius:12px; font-weight:600; border:none;">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

<div class="ui-card">
    <div class="d-flex align-items-center gap-4 mb-4 pb-4" style="border-bottom:1px solid #e2e8f0;">
        <div style="width:64px; height:64px; background:#e0f2fe; border-radius:16px; display:flex; align-items:center; justify-content:center; color:#0369a1; font-size:1.8rem; flex-shrink:0;">
            <i class="bi bi-person"></i>
        </div>
        <div>
            <h4 class="fw-bold mb-1" style="color:#0f172a;">@Model.NombreCompleto</h4>
            <div class="d-flex align-items-center gap-2">
                @if (Model.Estado == "A")
                {
                    <span class="status-badge" style="background:#dcfce7; color:#166534;">
                        <i class="bi bi-check-circle me-1"></i>Activo
                    </span>
                }
                else
                {
                    <span class="status-badge" style="background:#f1f5f9; color:#64748b;">
                        <i class="bi bi-x-circle me-1"></i>Inactivo
                    </span>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="mb-3">
                <p class="mb-1" style="color:#94a3b8; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; font-weight:600;">Carnet de Identidad</p>
                <p class="mb-0 fw-semibold" style="color:#0f172a;">@Model.Ci</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <p class="mb-1" style="color:#94a3b8; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; font-weight:600;">Género</p>
                <p class="mb-0 fw-semibold" style="color:#0f172a;">
                    @(Model.Genero == "M" ? "Masculino" : Model.Genero == "F" ? "Femenino" : Model.Genero == "O" ? "Otro" : "No especificado")
                </p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <p class="mb-1" style="color:#94a3b8; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; font-weight:600;">Fecha de Nacimiento</p>
                <p class="mb-0 fw-semibold" style="color:#0f172a;">
                    @(Model.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "No registrado")
                </p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <p class="mb-1" style="color:#94a3b8; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; font-weight:600;">Celular</p>
                <p class="mb-0 fw-semibold" style="color:#0f172a;">
                    @(string.IsNullOrEmpty(Model.Celular) ? "—" : Model.Celular)
                </p>
            </div>
        </div>
        <div class="col-md-12">
            <div class="mb-3">
                <p class="mb-1" style="color:#94a3b8; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em; font-weight:600;">Correo Electrónico</p>
                @if (!string.IsNullOrEmpty(Model.Correo))
                {
                    <a href="mailto:@Model.Correo" class="fw-semibold" style="color:#0369a1; text-decoration:none;">@Model.Correo</a>
                }
                else
                {
                    <p class="mb-0 fw-semibold" style="color:#94a3b8;">—</p>
                }
            </div>
        </div>
    </div>
</div>
