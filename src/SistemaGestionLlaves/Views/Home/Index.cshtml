@model SistemaGestionLlaves.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <!-- Resumen Principal -->
    <div class="col-lg-8">
        <div class="row g-4 mb-4">
            <!-- Tarjeta 1: Total Llaves -->
            <div class="col-md-6">
                <div class="ui-card bg-teal-card d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="fs-5 fw-semibold"><i class="bi bi-building"></i> Inventario</span>
                            <span class="badge bg-light text-dark">Total</span>
                        </div>
                        <h4 class="mb-1">UPDS Gestión</h4>
                        <p class="mb-4 opacity-75">Control de Accesos Centralizado</p>
                    </div>
                    <div class="d-flex justify-content-between align-items-end mt-4">
                        <div>
                            <small class="opacity-75 d-block">Llaves Activas</small>
                            <span class="fs-3 fw-bold">@Model.TotalLlaves</span>
                        </div>
                        <i class="bi bi-key-fill fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>

            <!-- Tarjeta 2: Préstamos Activos -->
            <div class="col-md-6">
                <div class="ui-card text-center d-flex flex-column justify-content-center">
                    <p class="card-title text-muted mb-2">Préstamos Activos</p>
                    <h2 class="big-number mb-1">@Model.PrestamosActivos</h2>
                    <p class="number-subtitle mb-4">Sincronizado a las @DateTime.Now.ToString("HH:mm")</p>
                    
                    <div class="d-flex justify-content-center gap-3 mt-2">
                        <a asp-controller="Prestamos" asp-action="Index" class="btn btn-light rounded-3 px-4 py-2 border">
                            <i class="bi bi-box-arrow-right d-block mb-1 fs-5 text-primary"></i>
                            Gestionar
                        </a>
                        <a asp-controller="Reservas" asp-action="Index" class="btn btn-light rounded-3 px-4 py-2 border">
                            <i class="bi bi-calendar-event d-block mb-1 fs-5 text-warning"></i>
                            @Model.ReservasHoy Reservas Hoy
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla Actividad Reciente -->
        <div class="ui-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="card-title mb-0">Actividad Reciente</h5>
                <a asp-controller="Reportes" asp-action="Prestamos" class="text-decoration-none text-muted small">Ver todo <i class="bi bi-chevron-right"></i></a>
            </div>
            
            <div class="table-responsive">
                <table class="table table-borderless align-middle">
                    <thead>
                        <tr>
                            <th>Persona</th>
                            <th>Llave / Ambiente</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ActividadReciente.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">No se registra actividad reciente.</td>
                            </tr>
                        }
                        @foreach (var item in Model.ActividadReciente)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-light rounded-3 p-2 text-primary">
                                            <i class="bi bi-person-circle fs-4"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-semibold">@item.PersonaNombre</h6>
                                            <small class="text-muted">@item.PersonaTipo</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <h6 class="mb-0 fw-semibold">@item.LlaveCodigo</h6>
                                    <small class="text-muted">@item.AmbienteNombre</small>
                                </td>
                                <td>
                                    <h6 class="mb-0 fw-semibold text-nowrap">@item.Fecha.ToLocalTime().ToString("dd/MM, HH:mm")</h6>
                                </td>
                                <td>
                                    @{
                                        var badgeClass = item.Estado switch {
                                            "A" => "status-warning",
                                            "D" => "status-success",
                                            _ => "status-info"
                                        };
                                        var label = item.Estado switch {
                                            "A" => "Prestado",
                                            "D" => "Devuelto",
                                            _ => item.Estado
                                        };
                                    }
                                    <span class="status-badge @badgeClass">@label</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Columna Derecha -->
    <div class="col-lg-4">
        <!-- Gráfico de Uso de Ambientes -->
        <div class="ui-card mb-4">
            <h5 class="card-title mb-4">Uso de Ambientes</h5>
            <div style="height: 250px;">
                <canvas id="chartAmbientes"></canvas>
            </div>
            <div class="mt-4 text-center">
                <small class="text-muted">Distribución por Tipo de Ambiente</small>
            </div>
        </div>
        
        <!-- Alertas / Notificaciones Críticas -->
        <div class="ui-card">
            <h5 class="card-title mb-4">
                <i class="bi bi-exclamation-octagon me-2 text-danger"></i>Acción Inmediata
            </h5>
            
            @if (!Model.AlertasCriticas.Any())
            {
                <div class="text-center py-4">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-check2-all fs-3"></i>
                    </div>
                    <p class="text-muted small mb-0">No hay llaves con retraso crítico. ¡Buen trabajo!</p>
                </div>
            }
            else
            {
                <div class="alert-list">
                    @foreach (var x in Model.AlertasCriticas)
                    {
                        <div class="d-flex align-items-start gap-3 mb-3 border-bottom pb-3">
                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-2">
                                <i class="bi bi-clock-fill"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between">
                                    <h6 class="mb-1 fw-semibold">@x.LlaveCodigo no devuelta</h6>
                                    <span class="badge bg-danger">@x.HorasRetraso h de retraso</span>
                                </div>
                                <p class="text-muted small mb-1">Solicitante: <strong>@x.PersonaNombre</strong></p>
                                <p class="text-muted small mb-0">Venció: @x.FechaVencimiento.ToLocalTime().ToString("dd/MM HH:mm")</p>
                            </div>
                        </div>
                    }
                </div>
                <div class="mt-2 text-center">
                    <a asp-controller="Reportes" asp-action="PrestamosVencidos" class="btn btn-sm btn-outline-danger px-3 rounded-pill">
                        Ver todos los retrasos
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Gráfico de Tendencia (Ancho Completo) -->
<div class="row">
    <div class="col-12">
        <div class="ui-card">
            <h5 class="card-title mb-4">Tendencia de Préstamos</h5>
            <div style="height: 300px;">
                <canvas id="chartHistorico"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // 1. Gráfico Dona: Ambientes
        const ctxAmbientes = document.getElementById('chartAmbientes').getContext('2d');
        new Chart(ctxAmbientes, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.UsoPorTipo.Select(x => x.Tipo))),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.UsoPorTipo.Select(x => x.Cantidad))),
                    backgroundColor: ['#0369a1', '#0ea5e9', '#38bdf8', '#7dd3fc', '#bae6fd'],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 12, padding: 15 } }
                }
            }
        });

        // 2. Gráfico Barra: Histórico
        const ctxHistorico = document.getElementById('chartHistorico').getContext('2d');
        new Chart(ctxHistorico, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.HistoricoPrestamos.Select(x => x.Mes))),
                datasets: [{
                    label: 'Cantidad de Préstamos',
                    data: @Html.Raw(Json.Serialize(Model.HistoricoPrestamos.Select(x => x.Cantidad))),
                    borderColor: '#0369a1',
                    backgroundColor: 'rgba(3, 105, 161, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#0369a1'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, grid: { display: false } },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}
