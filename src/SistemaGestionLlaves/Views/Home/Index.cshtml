@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid dashboard">

    <!-- TARJETAS -->
    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="dash-card purple">
                <div>
                    <p>Total Llaves</p>
                    <h2>1248</h2>
                </div>
                <i class="bi bi-key-fill"></i>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dash-card blue">
                <div>
                    <p>Préstamos Activos</p>
                    <h2>45</h2>
                </div>
                <i class="bi bi-arrow-left-right"></i>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dash-card orange">
                <div>
                    <p>Reservas Hoy</p>
                    <h2>18</h2>
                </div>
                <i class="bi bi-calendar-check"></i>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dash-card green">
                <div>
                    <p>Ambientes</p>
                    <h2>160</h2>
                </div>
                <i class="bi bi-door-open"></i>
            </div>
        </div>

    </div>

    <!-- GRAFICO -->
    <div class="row g-4">

        <div class="col-lg-8">

            <div class="chart-card">

                <div class="d-flex justify-content-between mb-3">
                    <h5>Actividad del Sistema</h5>
                    <small class="text-muted">Últimos 7 días</small>
                </div>

                <canvas id="chartActividad"></canvas>

            </div>

        </div>

        <!-- ACTIVIDAD RECIENTE -->

        <div class="col-lg-4">

            <div class="activity-card">

                <h5 class="mb-3">Actividad Reciente</h5>

                <div class="activity-item">
                    <i class="bi bi-person-circle"></i>
                    <div>
                        <strong>Juan Pérez</strong>
                        <p>Prestó llave L-302</p>
                    </div>
                </div>

                <div class="activity-item">
                    <i class="bi bi-person-circle"></i>
                    <div>
                        <strong>Ana Gómez</strong>
                        <p>Reservó Aula 105</p>
                    </div>
                </div>

                <div class="activity-item">
                    <i class="bi bi-person-circle"></i>
                    <div>
                        <strong>Carlos Ruiz</strong>
                        <p>Devolvió llave AUD-1</p>
                    </div>
                </div>

            </div>

        </div>

    </div>

</div>


@section Scripts{

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
(function () {
    const ctx = document.getElementById('chartActividad').getContext('2d');

    const gradPurple = ctx.createLinearGradient(0, 0, 0, 280);
    gradPurple.addColorStop(0, 'rgba(124,58,237,0.25)');
    gradPurple.addColorStop(1, 'rgba(124,58,237,0)');

    const gradBlue = ctx.createLinearGradient(0, 0, 0, 280);
    gradBlue.addColorStop(0, 'rgba(14,165,233,0.2)');
    gradBlue.addColorStop(1, 'rgba(14,165,233,0)');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'],
            datasets: [
                {
                    label: 'Préstamos',
                    data: [12, 19, 10, 15, 18, 9, 14],
                    borderColor: '#7c3aed',
                    backgroundColor: gradPurple,
                    pointBackgroundColor: '#7c3aed',
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    tension: 0.45,
                    fill: true,
                    borderWidth: 2.5
                },
                {
                    label: 'Reservas',
                    data: [5, 8, 6, 10, 7, 4, 9],
                    borderColor: '#0ea5e9',
                    backgroundColor: gradBlue,
                    pointBackgroundColor: '#0ea5e9',
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    tension: 0.45,
                    fill: true,
                    borderWidth: 2.5
                }
            ]
        },
        options: {
            responsive: true,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: {
                    position: 'top',
                    labels: {
                        usePointStyle: true,
                        pointStyle: 'circle',
                        padding: 20,
                        font: { family: 'Inter', size: 13, weight: '600' }
                    }
                },
                tooltip: {
                    backgroundColor: '#fff',
                    titleColor: '#1e1b4b',
                    bodyColor: '#6b7280',
                    borderColor: '#e5e7eb',
                    borderWidth: 1,
                    padding: 12,
                    cornerRadius: 12,
                    titleFont: { family: 'Inter', weight: '700' },
                    bodyFont: { family: 'Inter' }
                }
            },
            scales: {
                x: {
                    grid: { display: false },
                    ticks: { font: { family: 'Inter', size: 12 }, color: '#9ca3af' },
                    border: { display: false }
                },
                y: {
                    grid: { color: '#f3f4f6' },
                    ticks: { font: { family: 'Inter', size: 12 }, color: '#9ca3af', stepSize: 5 },
                    border: { display: false }
                }
            }
        }
    });
})();
</script>

}