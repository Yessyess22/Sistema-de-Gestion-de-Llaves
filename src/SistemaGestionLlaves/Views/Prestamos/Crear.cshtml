@{
    ViewData["Title"] = "Nuevo Préstamo";
}

<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold" style="color:#0f172a; font-size:1.4rem; margin-bottom:2px;">
            <i class="bi bi-plus-circle me-2" style="color:#0369a1;"></i>Registrar Préstamo
        </h2>
        <p class="mb-0" style="color:#64748b; font-size:0.875rem;">Complete los datos para entregar una llave</p>
    </div>
    <a asp-controller="Prestamos" asp-action="Index"
       class="btn d-flex align-items-center gap-2 px-4 py-2"
       style="background:#f1f5f9; color:#64748b; border-radius:12px; font-weight:600; border:none;">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<!-- Toast -->
<div id="toast-box" class="position-fixed top-0 end-0 p-3" style="z-index:9999;"></div>

<!-- Formulario -->
<div class="ui-card" style="max-width:680px;">
    <h3 class="card-title mb-4">Datos del Préstamo</h3>

    <div id="alertMsg" class="alert d-flex align-items-center gap-2 mb-4"
         style="display:none !important; border:none; border-radius:12px;"></div>

    <div class="row g-3">

        <!-- Llave -->
        <div class="col-12">
            <label for="idLlave" class="form-label fw-600"
                   style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">
                Llave <span class="text-danger">*</span>
            </label>
            <select id="idLlave" class="form-select search-select"
                    style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
                <option value="">-- Seleccione una llave disponible --</option>
                @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewData["Llaves"]!)
                {
                    <option value="@item.Value" selected="@(item.Value == ViewData["SelectedIdLlave"]?.ToString())">@item.Text</option>
                }
            </select>
        </div>

        <!-- Persona -->
        <div class="col-12">
            <label for="idPersona" class="form-label fw-600"
                   style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">
                Persona <span class="text-danger">*</span>
            </label>
            <select id="idPersona" class="form-select search-select"
                    style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
                <option value="">-- Seleccione la persona --</option>
                @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewData["Personas"]!)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>
        </div>

        <!-- Fecha devolución esperada -->
        <div class="col-md-6">
            <label for="fechaDevolucion" class="form-label fw-600"
                   style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">
                Devolución Esperada
            </label>
            <input type="datetime-local" id="fechaDevolucion" class="form-control"
                   style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;" />
        </div>

        <!-- Observaciones -->
        <div class="col-12">
            <label for="observaciones" class="form-label fw-600"
                   style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">
                Observaciones
            </label>
            <textarea id="observaciones" class="form-control" rows="2" maxlength="300"
                      placeholder="Opcional..."
                      style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px; resize:none;"></textarea>
        </div>

        <!-- Firma Digital -->
        <div class="col-12">
            <label class="form-label fw-600"
                   style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">
                Firma del Solicitante <span class="text-danger">*</span>
            </label>
            <div class="p-2 border rounded-3 bg-white" style="border-color:#e2e8f0 !important;">
                <canvas id="signature-pad" class="w-100" style="height: 180px; touch-action: none; cursor: crosshair;"></canvas>
            </div>
            <div class="d-flex justify-content-between mt-2">
                <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Firme sobre el recuadro blanco</small>
                <button type="button" id="btnClearSignature" class="btn btn-sm btn-link text-danger text-decoration-none p-0">
                    <i class="bi bi-eraser me-1"></i>Limpiar Firma
                </button>
            </div>
        </div>

        <!-- Botones -->
        <div class="col-12 d-flex gap-3 mt-2">
            <button id="btnGuardar" onclick="registrarPrestamo()" class="btn px-5 py-2"
                    style="background:#0369a1; color:white; border-radius:12px; font-weight:600; border:none;">
                <i class="bi bi-check-lg me-1"></i>Registrar Préstamo
            </button>
            <a asp-controller="Prestamos" asp-action="Index" class="btn px-4 py-2"
               style="background:#f1f5f9; color:#64748b; border-radius:12px; font-weight:600; border:none;">
                Cancelar
            </a>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>
<script>
    const canvas = document.getElementById('signature-pad');
    const signaturePad = new SignaturePad(canvas, {
        backgroundColor: 'rgba(255, 255, 255, 0)',
        penColor: 'rgb(0, 0, 0)'
    });

    // Ajustar el tamaño del canvas
    function resizeCanvas() {
        const ratio =  Math.max(window.devicePixelRatio || 1, 1);
        canvas.width = canvas.offsetWidth * ratio;
        canvas.height = canvas.offsetHeight * ratio;
        canvas.getContext("2d").scale(ratio, ratio);
        signaturePad.clear();
    }
    
    // Restricción de fecha mínima (hoy)
    function setMinDate() {
        const now = new Date();
        const offset = now.getTimezoneOffset() * 60000;
        const localISOTime = (new Date(now - offset)).toISOString().slice(0, 16);
        document.getElementById('fechaDevolucion').min = localISOTime;
    }

    window.onresize = resizeCanvas;
    resizeCanvas();
    setMinDate();

    document.getElementById('btnClearSignature').addEventListener('click', () => signaturePad.clear());

    async function registrarPrestamo() {
        const idLlave    = parseInt(document.getElementById('idLlave').value);
        const idPersona  = parseInt(document.getElementById('idPersona').value);
        const fechaRaw   = document.getElementById('fechaDevolucion').value;
        const obs        = document.getElementById('observaciones').value.trim();

        if (!idLlave)   return mostrarAlert('Debe seleccionar una llave.', false);
        if (!idPersona) return mostrarAlert('Debe seleccionar una persona.', false);
        
        if (signaturePad.isEmpty()) {
            return mostrarAlert('La firma del solicitante es obligatoria.', false);
        }

        const idUsuario = parseInt(document.querySelector('meta[name="uid"]')?.content ?? '0') || 1;

        const payload = {
            idLlave,
            idPersona,
            idUsuario,
            fechaHoraDevolucionEsperada: fechaRaw ? new Date(fechaRaw).toISOString() : null,
            observaciones: obs || null,
            firmaBase64: signaturePad.toDataURL("image/png")
        };

        const btn = document.getElementById('btnGuardar');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Guardando…';

        try {
            const res  = await fetch('/api/prestamos', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const json = await res.json();

            if (json.exito) {
                mostrarAlert(json.mensaje, true);
                setTimeout(() => window.location.href = '@Url.Action("Index", "Prestamos")', 1200);
            } else {
                mostrarAlert(json.mensaje, false);
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Registrar Préstamo';
            }
        } catch {
            mostrarAlert('Error de conexión. Intente nuevamente.', false);
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Registrar Préstamo';
        }
    }

    function mostrarAlert(msg, exito) {
        const el = document.getElementById('alertMsg');
        el.style.display = 'flex';
        el.style.background = exito ? '#dcfce7' : '#fee2e2';
        el.style.color      = exito ? '#166534' : '#991b1b';
        el.innerHTML = `<i class="bi bi-${exito ? 'check-circle-fill' : 'exclamation-circle-fill'}"></i> ${msg}`;
    }
</script>
}
