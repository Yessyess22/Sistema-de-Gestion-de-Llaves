@model SistemaGestionLlaves.Controllers.ImportResult
@{
    ViewData["Title"] = "Importación Masiva";
}

<div class="mb-4">
    <h2 class="fw-bold mb-0">Importación Masiva de Datos</h2>
    <p class="text-muted">Sube archivos de Excel para cargar datos rápidamente al sistema</p>
</div>

<div class="row g-4">
    <!-- Paso 1: Descargar Plantillas -->
    <div class="col-md-4">
        <div class="ui-card h-100">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-circle me-3">
                    <i class="bi bi-download"></i>
                </div>
                <h5 class="fw-bold mb-0">1. Descargar Plantillas</h5>
            </div>
            <p class="small text-muted mb-4">Usa estos archivos base para asegurar que el formato sea el correcto.</p>
            
            <div class="d-grid gap-2">
                <a asp-action="DescargarPlantilla" asp-route-tipo="personas" class="btn btn-outline-primary text-start">
                    <i class="bi bi-file-earmark-excel me-2"></i> Plantilla Personas
                </a>
                <a asp-action="DescargarPlantilla" asp-route-tipo="ambientes" class="btn btn-outline-primary text-start">
                    <i class="bi bi-file-earmark-excel me-2"></i> Plantilla Ambientes
                </a>
                <a asp-action="DescargarPlantilla" asp-route-tipo="llaves" class="btn btn-outline-primary text-start">
                    <i class="bi bi-file-earmark-excel me-2"></i> Plantilla Llaves
                </a>
            </div>
        </div>
    </div>

    <!-- Paso 2: Subir Archivo -->
    <div class="col-md-8">
        <div class="ui-card h-100">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-success bg-opacity-10 text-success p-2 rounded-circle me-3">
                    <i class="bi bi-upload"></i>
                </div>
                <h5 class="fw-bold mb-0">2. Cargar y Procesar</h5>
            </div>
            <p class="small text-muted mb-4">Selecciona el tipo de dato que vas a subir y adjunta tu archivo Excel.</p>

            <form asp-action="Importar" method="post" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label fw-bold small">Tipo de Información</label>
                        <select name="tipo" class="form-select" required>
                            <option value="personas">Personas / Personal</option>
                            <option value="ambientes">Ambientes / Aulas</option>
                            <option value="llaves">Llaves Físicas</option>
                        </select>
                    </div>
                    <div class="col-md-7">
                        <label class="form-label fw-bold small">Archivo Excel (.xlsx)</label>
                        <input type="file" name="archivo" class="form-control" accept=".xlsx" required />
                    </div>
                    <div class="col-12 mt-4">
                        <button type="submit" class="btn btn-success w-100 py-2 rounded-pill fw-bold">
                            <i class="bi bi-play-circle me-2"></i>Iniciar Procesamiento
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Resultados -->
    @if (Model != null && !string.IsNullOrEmpty(Model.Tipo))
    {
        <div class="col-12">
            <div class="ui-card border-top border-4 @(Model.Success ? "border-success" : "border-danger")">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Resultados de Importación: @Model.Tipo.ToUpper()</h5>
                    @if (Model.Success)
                    {
                        <span class="badge bg-success rounded-pill px-3 py-2">PROCESO COMPLETADO</span>
                    }
                    else
                    {
                        <span class="badge bg-danger rounded-pill px-3 py-2">ERROR EN PROCESO</span>
                    }
                </div>

                <div class="row text-center mb-4">
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-3">
                            <div class="display-6 fw-bold text-success">@Model.RegistrosExitosos</div>
                            <small class="text-muted fw-bold">EXITOSOS</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-3">
                            <div class="display-6 fw-bold text-danger">@Model.RegistrosFallidos</div>
                            <small class="text-muted fw-bold">FALLIDOS</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-3">
                            <div class="display-6 fw-bold text-warning">@Model.RegistrosSaltados</div>
                            <small class="text-muted fw-bold">EXISTENTES / SALTADOS</small>
                        </div>
                    </div>
                </div>

                @if (Model.Log.Any())
                {
                    <div class="mt-3">
                        <h6 class="fw-bold mb-2">Registro de Eventos:</h6>
                        <div class="bg-dark text-light p-3 rounded-3 small" style="max-height: 300px; overflow-y: auto; font-family: monospace;">
                            @foreach (var log in Model.Log)
                            {
                                <div class="mb-1 d-flex">
                                    <span class="text-muted me-2">[@DateTime.Now.ToString("HH:mm:ss")]</span>
                                    <span>@log</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
