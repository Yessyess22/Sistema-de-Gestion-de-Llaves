@{
    ViewData["Title"] = "Nueva Reserva";
}

<div class="d-flex align-items-center mb-4">
    <h2 class="fw-bold" style="color:#0f172a;">
        <i class="bi bi-calendar-plus me-2" style="color:#0369a1;"></i>Nueva Reserva
    </h2>
</div>

<div class="ui-card p-4">

    <div class="mb-3">
        <label class="form-label">Llave</label>
        <select id="IdLlave" class="form-select search-select">
            <option value="">Seleccione una llave</option>
            @foreach (var item in ViewBag.Llaves)
            {
                <option value="@item.Value">@item.Text</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Persona</label>
        <select id="IdPersona" class="form-select search-select">
            <option value="">Seleccione una persona</option>
            @foreach (var item in ViewBag.Personas)
            {
                <option value="@item.Value">@item.Text</option>
            }
        </select>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha Inicio</label>
            <input type="datetime-local" id="FechaInicio" class="form-control" />
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha Fin</label>
            <input type="datetime-local" id="FechaFin" class="form-control" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button onclick="guardarReserva()"
                class="btn px-4 py-2"
                style="background:#0369a1; color:white; border-radius:12px; font-weight:600;">
            <i class="bi bi-save me-1"></i>Guardar
        </button>

        <a asp-action="Index"
           class="btn px-4 py-2"
           style="background:#f1f5f9; color:#64748b; border-radius:12px;">
            Cancelar
        </a>
    </div>

</div>

<div id="toast-box" class="position-fixed top-0 end-0 p-3" style="z-index:9999;"></div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    const now = new Date();
    const offset = now.getTimezoneOffset() * 60000;
    const localISOTime = (new Date(now - offset)).toISOString().slice(0, 16);
    
    const inputInicio = document.getElementById('FechaInicio');
    const inputFin = document.getElementById('FechaFin');
    
    if (inputInicio) inputInicio.min = localISOTime;
    if (inputFin) inputFin.min = localISOTime;
    
    // Validar que fin sea mayor a inicio dinámicamente
    inputInicio?.addEventListener('change', function() {
        if (inputFin) inputFin.min = this.value;
    });
});

async function guardarReserva() {

    const model = {
        IdLlave: document.getElementById("IdLlave").value,
        IdPersona: document.getElementById("IdPersona").value,
        FechaInicio: document.getElementById("FechaInicio").value,
        FechaFin: document.getElementById("FechaFin").value,
        IdUsuario: 1 // 🔥 luego lo conectamos al login
    };

    if (!model.IdLlave || !model.IdPersona || !model.FechaInicio || !model.FechaFin) {
        mostrarToast("Complete todos los campos.", false);
        return;
    }

    const res = await fetch("/api/reservas", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(model)
    });

    const json = await res.json();

    mostrarToast(json.mensaje, json.exito);

    if (json.exito) {
        setTimeout(() => {
            window.location.href = "/Reservas";
        }, 1200);
    }
}

function mostrarToast(msg, exito) {
    const id = 'toast-' + Date.now();
    const color = exito ? '#dcfce7' : '#fee2e2';
    const textColor = exito ? '#166534' : '#991b1b';

    document.getElementById('toast-box').insertAdjacentHTML('beforeend', `
        <div id="${id}" class="toast show"
             style="background:${color}; color:${textColor};
                    border:none; border-radius:12px; padding:12px; margin-bottom:8px;">
            ${msg}
        </div>`);

    setTimeout(() => document.getElementById(id)?.remove(), 4000);
}

</script>
}