@model IEnumerable<SistemaGestionLlaves.Models.Auditoria>
@{
    ViewData["Title"] = "Registro de Auditoría";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">Registro de Auditoría</h2>
        <p class="text-muted">Trazabilidad completa de cambios en el sistema</p>
    </div>
    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3">
        <i class="bi bi-shield-lock-fill fs-3"></i>
    </div>
</div>

<div class="ui-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="bg-light">
                <tr>
                    <th>Fecha y Hora</th>
                    <th>Acción</th>
                    <th>Entidad</th>
                    <th>Usuario</th>
                    <th>Detalles</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">No hay registros de auditoría disponibles.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-nowrap">
                            <h6 class="mb-0 fw-semibold">@item.DateTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</h6>
                        </td>
                        <td>
                            @{
                                var badgeClass = item.Type switch {
                                    "Create" => "bg-success bg-opacity-10 text-success",
                                    "Update" => "bg-warning bg-opacity-10 text-warning",
                                    "Delete" => "bg-danger bg-opacity-10 text-danger",
                                    _ => "bg-secondary bg-opacity-10 text-secondary"
                                };
                            }
                            <span class="badge @badgeClass px-3 py-2 rounded-pill">
                                @(item.Type == "Create" ? "CREACIÓN" : item.Type == "Update" ? "MODIFICACIÓN" : "ELIMINACIÓN")
                            </span>
                        </td>
                        <td>
                            <span class="fw-semibold">@item.TableName</span>
                            <br />
                            <small class="text-muted">ID: @item.PrimaryKey</small>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-person-circle text-primary"></i>
                                <span>@(item.UserId ?? "Sistema")</span>
                            </div>
                        </td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modal-@item.Id">
                                <i class="bi bi-eye me-1"></i> Ver Cambios
                            </button>

                            <!-- Modal Detalles -->
                            <div class="modal fade" id="modal-@item.Id" tabindex="-1">
                                <div class="modal-dialog modal-lg modal-dialog-centered">
                                    <div class="modal-content border-0 shadow">
                                        <div class="modal-header border-0 bg-light">
                                            <h5 class="modal-title fw-bold">Detalles del Cambio - @item.TableName</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body p-4">
                                            <div class="row g-4">
                                                @if (item.Type == "Update")
                                                {
                                                    <div class="col-12">
                                                        <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-list-check me-2"></i>Columnas Afectadas:</h6>
                                                        <div class="d-flex flex-wrap gap-2">
                                                            @foreach (var col in Newtonsoft.Json.JsonConvert.DeserializeObject<List<string>>(item.AffectedColumns ?? "[]"))
                                                            {
                                                                <span class="badge bg-light text-dark border">@col</span>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                                <div class="col-md-6">
                                                    <div class="p-3 bg-danger bg-opacity-10 rounded-3 h-100">
                                                        <h6 class="fw-bold text-danger mb-3">Valor Anterior (Snapshot)</h6>
                                                        <pre class="bg-white p-2 rounded small" style="max-height: 200px; overflow-y: auto;">@item.OldValues</pre>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="p-3 bg-success bg-opacity-10 rounded-3 h-100">
                                                        <h6 class="fw-bold text-success mb-3">Valor Nuevo (Final)</h6>
                                                        <pre class="bg-white p-2 rounded small" style="max-height: 200px; overflow-y: auto;">@item.NewValues</pre>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer border-0">
                                            <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cerrar</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
