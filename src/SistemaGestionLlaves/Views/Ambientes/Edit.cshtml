@model SistemaGestionLlaves.Models.Ambiente
@{
    ViewData["Title"] = "Editar Ambiente";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold" style="color:#0f172a; font-size:1.4rem; margin-bottom:2px;">
            <i class="bi bi-pencil-square me-2" style="color:#0369a1;"></i>Editar Ambiente
        </h2>
        <p class="mb-0" style="color:#64748b; font-size:0.875rem;">Actualiza la información del espacio físico.</p>
    </div>
    <a asp-action="Index" class="btn px-4 py-2" style="background:#f1f5f9; color:#64748b; border-radius:12px; font-weight:600; border:none;">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="ui-card">
    <form asp-action="Edit" method="post" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="IdAmbiente" />

        <div class="col-md-6">
            <label asp-for="Codigo" class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Código</label>
            <input asp-for="Codigo" class="form-control" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;" data-validation="alphanumeric" />
            <span asp-validation-for="Codigo" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Nombre" class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Nombre / Descripción</label>
            <input asp-for="Nombre" class="form-control" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;" data-validation="alphanumeric" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Tipo de Ambiente</label>
            <select asp-for="IdTipo" class="form-select search-select" asp-items="ViewBag.Tipos" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
            </select>
            <span asp-validation-for="IdTipo" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Ubicacion" class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Ubicación</label>
            <input asp-for="Ubicacion" class="form-control" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;" data-validation="alphanumeric" />
            <span asp-validation-for="Ubicacion" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Estado" class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Estado</label>
            <select asp-for="Estado" class="form-select" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
                <option value="A">Activo</option>
                <option value="I">Inactivo</option>
            </select>
            <span asp-validation-for="Estado" class="text-danger"></span>
        </div>

        <div class="col-12 d-flex gap-2 pt-2">
            <button type="submit" class="btn px-4 py-2" style="background:#0369a1; color:white; border-radius:12px; font-weight:600; border:none;">
                <i class="bi bi-check2 me-1"></i>Actualizar Ambiente
            </button>
            <a asp-action="Index" class="btn px-4 py-2" style="background:#f1f5f9; color:#64748b; border-radius:12px; font-weight:600; border:none;">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}