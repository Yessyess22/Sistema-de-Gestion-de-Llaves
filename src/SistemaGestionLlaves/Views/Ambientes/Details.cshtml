@model SistemaGestionLlaves.Models.Ambiente
@{
    ViewData["Title"] = "Detalle de Ambiente";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold" style="color:#0f172a; font-size:1.4rem; margin-bottom:2px;">
            <i class="bi bi-door-open me-2" style="color:#0369a1;"></i>Detalle de Ambiente
        </h2>
        <p class="mb-0" style="color:#64748b; font-size:0.875rem;">Información del ambiente y sus llaves vinculadas.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.IdAmbiente" class="btn px-4 py-2" style="background:#e0f2fe; color:#0369a1; border-radius:12px; font-weight:600; border:none;">
            <i class="bi bi-pencil me-1"></i>Editar
        </a>
        <a asp-action="Index" class="btn px-4 py-2" style="background:#f1f5f9; color:#64748b; border-radius:12px; font-weight:600; border:none;">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="ui-card">
            <h3 class="card-title">Información General</h3>
            <div class="mb-4">
                <div style="color:#94a3b8; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em;">Código</div>
                <div class="fw-semibold" style="color:#0f172a;">@Model.Codigo</div>
            </div>
            <div class="mb-4">
                <div style="color:#94a3b8; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em;">Nombre/Descripción</div>
                <div class="fw-semibold" style="color:#0f172a;">@Model.Nombre</div>
            </div>
            <div class="mb-4">
                <div style="color:#94a3b8; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em;">Tipo</div>
                <div><span class="status-badge" style="background:#ede9fe; color:#6d28d9;">@Model.TipoAmbiente?.NombreTipo</span></div>
            </div>
            <div class="mb-4">
                <div style="color:#94a3b8; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em;">Ubicación</div>
                <div style="color:#334155;">@Model.Ubicacion</div>
            </div>
            <div>
                <div style="color:#94a3b8; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.05em;">Estado</div>
                <div>
                    @{
                        var (bg, fg, label) = Model.Estado switch
                        {
                            "A" => ("#dcfce7", "#166534", "Activo"),
                            _ => ("#f1f5f9", "#64748b", "Inactivo")
                        };
                    }
                    <span class="status-badge" style="background:@bg; color:@fg;">@label</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="ui-card">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h3 class="card-title mb-0">Llaves Vinculadas</h3>
                <span class="badge rounded-pill" style="background:#e0f2fe; color:#0369a1;">@Model.Llaves.Count llave(s)</span>
            </div>

            @if (!Model.Llaves.Any())
            {
                <div class="text-center py-5" style="color:#94a3b8;">
                    <i class="bi bi-key" style="font-size:3rem; display:block; margin-bottom:12px;"></i>
                    <p class="mb-0">Este ambiente no tiene llaves registradas.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-borderless mb-0">
                        <thead>
                            <tr>
                                <th>Código Llave</th>
                                <th>Copias</th>
                                <th>Estado</th>
                                <th style="text-align:right;">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var llave in Model.Llaves)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-key@(llave.EsMaestra ? "-fill" : "")" style="color:#0369a1;"></i>
                                            <span class="fw-bold" style="color:#0f172a;">@llave.Codigo</span>
                                            @if (llave.EsMaestra) { <span class="badge" style="background:#ede9fe; color:#6d28d9; font-size:0.6rem;">MAESTRA</span> }
                                        </div>
                                    </td>
                                    <td style="color:#334155;">@llave.NumCopias</td>
                                    <td>
                                        @{
                                            var (lbg, lfg, llabel) = llave.Estado switch
                                            {
                                                "D" => ("#dcfce7", "#166534", "Disponible"),
                                                "P" => ("#fef3c7", "#92400e", "Prestada"),
                                                "R" => ("#dbeafe", "#1e40af", "Reservada"),
                                                _ => ("#f1f5f9", "#64748b", "Inactiva")
                                            };
                                        }
                                        <span class="status-badge" style="background:@lbg; color:@lfg;">@llabel</span>
                                    </td>
                                    <td style="text-align:right;">
                                        <a asp-controller="LlavesView" asp-action="Details" asp-route-id="@llave.IdLlave" 
                                           class="btn btn-sm" style="background:#f1f5f9; color:#0369a1; border-radius:8px; border:none; padding:6px 10px;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>