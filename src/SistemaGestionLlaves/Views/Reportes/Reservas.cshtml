@{
    ViewData["Title"] = "Reporte de Reservas";
    ViewData["HideTopSubtitle"] = true;
    ViewData["HideTopHeader"] = true;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold" style="color:#0f172a; font-size:1.4rem; margin-bottom:2px;">
            <i class="bi bi-calendar-check me-2" style="color:#0369a1;"></i>Reporte de Reservas
        </h2>
        <p class="mb-0" style="color:#64748b; font-size:0.875rem;">Filtro por fechas y ambiente.</p>
    </div>
    <a asp-controller="Reportes" asp-action="Index" class="btn px-4 py-2" style="background:#f1f5f9; color:#64748b; border-radius:12px; border:none; font-weight:600;">
        <i class="bi bi-arrow-left me-1"></i> Volver a Reportes
    </a>
</div>

<div class="ui-card">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="card-title mb-0">Reservas</h3>
        <span id="reservasTotal" style="color:#94a3b8; font-size:0.85rem;">0 resultado(s)</span>
    </div>

    <div id="alertReservas" class="alert d-flex align-items-center gap-2 mb-3" style="display:none; border:none; border-radius:12px;"></div>

    <div class="row g-3 align-items-end mb-3">
        <div class="col-md-2">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Desde</label>
            <input type="date" id="rDesde" class="form-control" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
        </div>
        <div class="col-md-2">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Hasta</label>
            <input type="date" id="rHasta" class="form-control" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
        </div>
        <div class="col-md-4">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Ambiente</label>
            <select id="rAmbiente" class="form-select" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
                <option value="">Todos</option>
                @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewData["Ambientes"]!)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button id="btnFiltrarReservas" class="btn px-4 py-2" onclick="cargarReservas()" style="background:#0369a1; color:white; border-radius:12px; border:none; font-weight:600;">Filtrar</button>
            <button class="btn px-4 py-2" onclick="exportarReservasPdf()" style="background:#f1f5f9; color:#334155; border-radius:12px; border:none; font-weight:600;">
                <i class="bi bi-file-earmark-pdf me-1"></i>Exportar PDF
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-borderless mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Persona</th>
                    <th>Llave</th>
                    <th>Ambiente</th>
                    <th>Inicio</th>
                    <th>Fin</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody id="tablaReservas"></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    function qs(base, params) {
        const url = new URL(base, window.location.origin);
        Object.entries(params).forEach(([k, v]) => {
            if (v !== null && v !== undefined && v !== '') url.searchParams.append(k, v);
        });
        return url.pathname + url.search;
    }

    function fmtDate(v) {
        if (!v) return '—';
        return new Date(v).toLocaleString('es-BO', { dateStyle: 'short', timeStyle: 'short' });
    }

    function estadoBadge(estado) {
        const map = {
            P: ['#e0f2fe', '#0369a1', 'Pendiente'],
            C: ['#dbeafe', '#1e40af', 'Confirmada'],
            U: ['#dcfce7', '#166534', 'Utilizada'],
            X: ['#f1f5f9', '#64748b', 'Cancelada']
        };
        const cfg = map[estado] || ['#f1f5f9', '#64748b', estado];
        return `<span class="status-badge" style="background:${cfg[0]}; color:${cfg[1]};">${cfg[2]}</span>`;
    }

    async function cargarReservas() {
        const desde = document.getElementById('rDesde').value;
        const hasta = document.getElementById('rHasta').value;

        if (desde && hasta && desde > hasta) {
            mostrarAlertReservas('El rango de fechas es inválido: "Desde" no puede ser mayor que "Hasta".', false);
            return;
        }

        const btn = document.getElementById('btnFiltrarReservas');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Filtrando...';

        const url = qs('/Reportes/ReservasData', {
            fechaDesde: desde,
            fechaHasta: hasta,
            idAmbiente: document.getElementById('rAmbiente').value
        });

        try {
            const res = await fetch(url);
            if (!res.ok) {
                throw new Error('No se pudo obtener la información de reservas.');
            }

            const json = await res.json();
            document.getElementById('reservasTotal').textContent = `${json.total} resultado(s)`;

            if (!json.data || json.data.length === 0) {
                document.getElementById('tablaReservas').innerHTML = `
                    <tr>
                        <td colspan="7" class="text-center py-4" style="color:#94a3b8;">
                            No hay reservas para los filtros seleccionados.
                        </td>
                    </tr>`;
                mostrarAlertReservas('No hay datos para el filtro aplicado.', false);
                return;
            }

            ocultarAlertReservas();
            document.getElementById('tablaReservas').innerHTML = json.data.map(r => `
                <tr>
                    <td>#${r.idReserva}</td>
                    <td>${r.persona}</td>
                    <td>${r.llave}</td>
                    <td>${r.ambiente}</td>
                    <td>${fmtDate(r.fechaInicio)}</td>
                    <td>${fmtDate(r.fechaFin)}</td>
                    <td>${estadoBadge(r.estado)}</td>
                </tr>
            `).join('');
        } catch (error) {
            document.getElementById('reservasTotal').textContent = '0 resultado(s)';
            document.getElementById('tablaReservas').innerHTML = `
                <tr>
                    <td colspan="7" class="text-center py-4" style="color:#991b1b;">
                        Ocurrió un error al filtrar reservas. Intenta nuevamente.
                    </td>
                </tr>`;
            mostrarAlertReservas(error.message || 'Error inesperado en el filtrado.', false);
        } finally {
            btn.disabled = false;
            btn.innerHTML = 'Filtrar';
        }
    }

    function exportarReservasPdf() {
        const desde = document.getElementById('rDesde').value;
        const hasta = document.getElementById('rHasta').value;

        if (desde && hasta && desde > hasta) {
            mostrarAlertReservas('El rango de fechas es inválido: "Desde" no puede ser mayor que "Hasta".', false);
            return;
        }

        const url = qs('/Reportes/ExportarReservasPdf', {
            fechaDesde: desde,
            fechaHasta: hasta,
            idAmbiente: document.getElementById('rAmbiente').value
        });

        window.location.href = url;
    }

    function mostrarAlertReservas(msg, exito) {
        const el = document.getElementById('alertReservas');
        el.style.display = 'flex';
        el.style.background = exito ? '#dcfce7' : '#fee2e2';
        el.style.color = exito ? '#166534' : '#991b1b';
        el.innerHTML = `<i class="bi bi-${exito ? 'check-circle-fill' : 'exclamation-circle-fill'}"></i> ${msg}`;
    }

    function ocultarAlertReservas() {
        const el = document.getElementById('alertReservas');
        el.style.display = 'none';
        el.innerHTML = '';
    }

    document.addEventListener('DOMContentLoaded', cargarReservas);
</script>
}
