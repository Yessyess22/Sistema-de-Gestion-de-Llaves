@{
    ViewData["Title"] = "Préstamos Vencidos";
    ViewData["HideTopSubtitle"] = true;
    ViewData["HideTopHeader"] = true;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold" style="color:#0f172a; font-size:1.4rem; margin-bottom:2px;">
            <i class="bi bi-exclamation-triangle me-2" style="color:#dc2626;"></i>Préstamos Vencidos / No Devueltos
        </h2>
        <p class="mb-0" style="color:#64748b; font-size:0.875rem;">Préstamos activos cuya fecha límite de devolución ya fue superada.</p>
    </div>
    <a asp-controller="Reportes" asp-action="Index" class="btn px-4 py-2" style="background:#f1f5f9; color:#64748b; border-radius:12px; border:none; font-weight:600;">
        <i class="bi bi-arrow-left me-1"></i> Volver a Reportes
    </a>
</div>

<div class="ui-card">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="card-title mb-0">Vencidos</h3>
        <span id="vencTotal" style="color:#94a3b8; font-size:0.85rem;">0 resultado(s)</span>
    </div>

    <div class="row g-3 align-items-end mb-4">
        <div class="col-md-5">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Ambiente</label>
            <select id="vAmbiente" class="form-select" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
                <option value="">Todos</option>
                @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewData["Ambientes"]!)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button class="btn px-4 py-2" onclick="cargarVencidos()" style="background:#dc2626; color:white; border-radius:12px; border:none; font-weight:600;">Filtrar</button>
            <button class="btn px-4 py-2" onclick="exportarVencidosPdf()" style="background:#f1f5f9; color:#334155; border-radius:12px; border:none; font-weight:600;">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-borderless mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Persona</th>
                    <th>CI</th>
                    <th>Celular</th>
                    <th>Llave</th>
                    <th>Ambiente</th>
                    <th>Fecha Préstamo</th>
                    <th>Vto. Esperado</th>
                    <th>Días vencido</th>
                </tr>
            </thead>
            <tbody id="tablaVencidos"></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    function qs(base, params) {
        const url = new URL(base, window.location.origin);
        Object.entries(params).forEach(([k, v]) => {
            if (v !== null && v !== undefined && v !== '') url.searchParams.append(k, v);
        });
        return url.pathname + url.search;
    }

    function fmtDate(v) {
        if (!v) return '—';
        return new Date(v).toLocaleString('es-BO', { dateStyle: 'short', timeStyle: 'short' });
    }

    function urgenciaBadge(dias) {
        if (dias === 0) return `<span class="status-badge" style="background:#fef3c7;color:#92400e;">< 1 día</span>`;
        if (dias <= 2)  return `<span class="status-badge" style="background:#fed7aa;color:#9a3412;">${dias} día(s)</span>`;
        return `<span class="status-badge" style="background:#fee2e2;color:#991b1b;">${dias} día(s)</span>`;
    }

    async function cargarVencidos() {
        const url = qs('/Reportes/PrestamosVencidosData', {
            idAmbiente: document.getElementById('vAmbiente').value
        });

        const res = await fetch(url);
        const json = await res.json();

        document.getElementById('vencTotal').textContent = `${json.total} resultado(s)`;

        if (json.data.length === 0) {
            document.getElementById('tablaVencidos').innerHTML = `
                <tr><td colspan="9" class="text-center py-4" style="color:#64748b;">
                    <i class="bi bi-check-circle me-2" style="color:#16a34a;"></i>Sin préstamos vencidos.
                </td></tr>`;
            return;
        }

        document.getElementById('tablaVencidos').innerHTML = json.data.map(p => `
            <tr>
                <td>#${p.idPrestamo}</td>
                <td><strong>${p.persona}</strong></td>
                <td>${p.ci}</td>
                <td>${p.celular}</td>
                <td>${p.llave}</td>
                <td>${p.ambiente}</td>
                <td>${fmtDate(p.fechaHoraPrestamo)}</td>
                <td>${fmtDate(p.fechaEsperada)}</td>
                <td>${urgenciaBadge(p.diasVencido)}</td>
            </tr>
        `).join('');
    }

    function exportarVencidosPdf() {
        const url = qs('/Reportes/ExportarPrestamosVencidosPdf', {
            idAmbiente: document.getElementById('vAmbiente').value
        });
        window.location.href = url;
    }

    document.addEventListener('DOMContentLoaded', cargarVencidos);
</script>
}
