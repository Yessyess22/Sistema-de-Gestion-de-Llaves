@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Historial de Persona";
    ViewData["HideTopSubtitle"] = true;
    ViewData["HideTopHeader"] = true;
    var personas = ViewData["Personas"] as SelectList;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold" style="color:#0f172a; font-size:1.4rem; margin-bottom:2px;">
            <i class="bi bi-person-lines-fill me-2" style="color:#0369a1;"></i>Historial de Actividad por Persona
        </h2>
        <p class="mb-0" style="color:#64748b; font-size:0.875rem;">Consulta préstamos y reservas realizados por un individuo específico.</p>
    </div>
    <a asp-controller="Reportes" asp-action="Index" class="btn px-4 py-2" style="background:#f1f5f9; color:#64748b; border-radius:12px; border:none; font-weight:600;">
        <i class="bi bi-arrow-left me-1"></i> Volver a Reportes
    </a>
</div>

<div class="ui-card mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Seleccionar Persona</label>
            <select id="fPersona" asp-items="personas" class="form-select" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
                <option value="">-- Seleccionar Persona --</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Desde</label>
            <input type="date" id="fDesde" class="form-control" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
        </div>
        <div class="col-md-2">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Hasta</label>
            <input type="date" id="fHasta" class="form-control" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button class="btn px-4 py-2 w-100" onclick="cargarHistorial()" style="background:#0369a1; color:white; border-radius:12px; border:none; font-weight:600;">
                <i class="bi bi-search me-1"></i> Consultar
            </button>
            <button class="btn px-4 py-2" onclick="exportarPdf()" style="background:#f1f5f9; color:#334155; border-radius:12px; border:none; font-weight:600;">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
            </button>
        </div>
    </div>
</div>

<div class="ui-card">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr style="border-bottom: 2px solid #f1f5f9;">
                    <th style="color:#64748b; font-weight:600; font-size:0.85rem;">FECHA</th>
                    <th style="color:#64748b; font-weight:600; font-size:0.85rem;">TIPO</th>
                    <th style="color:#64748b; font-weight:600; font-size:0.85rem;">LLAVE</th>
                    <th style="color:#64748b; font-weight:600; font-size:0.85rem;">AMBIENTE</th>
                    <th style="color:#64748b; font-weight:600; font-size:0.85rem;">DETALLE</th>
                    <th style="color:#64748b; font-weight:600; font-size:0.85rem;">ESTADO</th>
                </tr>
            </thead>
            <tbody id="tablaHistorial">
                <tr>
                    <td colspan="6" class="text-center py-5" style="color:#94a3b8;">Selecciona una persona para ver su actividad.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    function qs(base, params) {
        const url = new URL(base, window.location.origin);
        Object.entries(params).forEach(([k, v]) => {
            if (v !== null && v !== undefined && v !== '') url.searchParams.append(k, v);
        });
        return url.pathname + url.search;
    }

    async function cargarHistorial() {
        const idPersona = document.getElementById('fPersona').value;
        const fDesde = document.getElementById('fDesde').value;
        const fHasta = document.getElementById('fHasta').value;

        if (!idPersona) {
            alert('Por favor selecciona una persona.');
            return;
        }

        if (fDesde && fHasta && fDesde > fHasta) {
            alert('La fecha inicial no puede ser posterior a la fecha final.');
            return;
        }

        const tbody = document.getElementById('tablaHistorial');
        tbody.innerHTML = `<tr><td colspan="6" class="text-center py-5"><div class="spinner-border text-primary spinner-border-sm" role="status"></div> Cargando historial...</td></tr>`;

        try {
            const url = qs('/Reportes/HistorialPersonaData', { idPersona, fechaDesde: fDesde, fechaHasta: fHasta });
            const res = await fetch(url);
            const json = await res.json();
            
            if (!res.ok) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center py-5 text-danger"><i class="bi bi-exclamation-triangle me-2"></i> ${json || 'Error al cargar datos'}</td></tr>`;
                return;
            }

            if (json.data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center py-5" style="color:#94a3b8;">No se encontró actividad para los filtros seleccionados.</td></tr>`;
                return;
            }

            tbody.innerHTML = json.data.map(item => `
                <tr>
                    <td style="font-size:0.9rem;">${new Date(item.fecha).toLocaleString()}</td>
                    <td><span class="badge ${item.tipo === 'Préstamo' ? 'bg-primary' : 'bg-info'}" style="border-radius:6px; font-weight:500;">${item.tipo}</span></td>
                    <td class="fw-medium">${item.llave}</td>
                    <td style="color:#64748b;">${item.ambiente}</td>
                    <td style="font-size:0.85rem;">${item.detalle}</td>
                    <td>${traducirEstado(item.estado, item.tipo)}</td>
                </tr>
            `).join('');
        } catch (error) {
            tbody.innerHTML = `<tr><td colspan="6" class="text-center py-5 text-danger"><i class="bi bi-exclamation-triangle me-2"></i> Error de conexión con el servidor.</td></tr>`;
        }
    }

    function traducirEstado(est, tipo) {
        if (tipo === 'Préstamo') {
            const map = { 'A': 'Activo', 'D': 'Devuelto', 'V': 'Vencido', 'C': 'Cancelado' };
            const colors = { 'A': '#0ea5e9', 'D': '#10b981', 'V': '#ef4444', 'C': '#94a3b8' };
            return `<span style="color:${colors[est] || '#64748b'}; font-weight:600;">${map[est] || est}</span>`;
        } else {
            const map = { 'P': 'Pendiente', 'C': 'Confirmada', 'U': 'Utilizada', 'X': 'Cancelada' };
            const colors = { 'P': '#f59e0b', 'C': '#10b981', 'U': '#6366f1', 'X': '#ef4444' };
            return `<span style="color:${colors[est] || '#64748b'}; font-weight:600;">${map[est] || est}</span>`;
        }
    }

    function exportarPdf() {
        const idPersona = document.getElementById('fPersona').value;
        if (!idPersona) {
            alert('Seleccione una persona primero.');
            return;
        }
        const url = qs('/Reportes/ExportarHistorialPersonaPdf', {
            idPersona,
            fechaDesde: document.getElementById('fDesde').value,
            fechaHasta: document.getElementById('fHasta').value
        });
        window.location.href = url;
    }
</script>
}
