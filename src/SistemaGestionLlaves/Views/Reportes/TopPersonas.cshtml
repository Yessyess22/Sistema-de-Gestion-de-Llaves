@{
    ViewData["Title"] = "Top Personas";
    ViewData["HideTopSubtitle"] = true;
    ViewData["HideTopHeader"] = true;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold" style="color:#0f172a; font-size:1.4rem; margin-bottom:2px;">
            <i class="bi bi-bar-chart-line me-2" style="color:#0369a1;"></i>Top Personas Solicitantes
        </h2>
        <p class="mb-0" style="color:#64748b; font-size:0.875rem;">Ranking de personas que más solicitan préstamos y reservas.</p>
    </div>
    <a asp-controller="Reportes" asp-action="Index" class="btn px-4 py-2" style="background:#f1f5f9; color:#64748b; border-radius:12px; border:none; font-weight:600;">
        <i class="bi bi-arrow-left me-1"></i> Volver a Reportes
    </a>
</div>

<div class="ui-card">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="card-title mb-0">Top Solicitantes</h3>
        <span id="topTotal" style="color:#94a3b8; font-size:0.85rem;">0 solicitudes</span>
    </div>

    <div class="row g-3 align-items-end mb-3">
        <div class="col-md-3">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Desde</label>
            <input type="date" id="tDesde" class="form-control" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
        </div>
        <div class="col-md-3">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Hasta</label>
            <input type="date" id="tHasta" class="form-control" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
        </div>
        <div class="col-md-2">
            <label class="form-label" style="color:#64748b; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em;">Top</label>
            <select id="tTop" class="form-select" style="border-color:#e2e8f0; background:#f8fafc; border-radius:12px;">
                <option value="5">Top 5</option>
                <option value="10" selected>Top 10</option>
                <option value="15">Top 15</option>
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button class="btn px-4 py-2" onclick="cargarTopPersonas()" style="background:#0369a1; color:white; border-radius:12px; border:none; font-weight:600;">Generar</button>
            <button class="btn px-4 py-2" onclick="exportarTopPersonasPdf()" style="background:#f1f5f9; color:#334155; border-radius:12px; border:none; font-weight:600;">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
            </button>
        </div>
    </div>

    <div class="row g-4 align-items-center">
        <div class="col-lg-8">
            <canvas id="topPersonasChart" height="120"></canvas>
        </div>
        <div class="col-lg-4">
            <div class="table-responsive">
                <table class="table table-borderless mb-0">
                    <thead>
                        <tr>
                            <th>Persona</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody id="tablaTopPersonas"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    let topChart;

    function qs(base, params) {
        const url = new URL(base, window.location.origin);
        Object.entries(params).forEach(([k, v]) => {
            if (v !== null && v !== undefined && v !== '') url.searchParams.append(k, v);
        });
        return url.pathname + url.search;
    }

    async function cargarTopPersonas() {
        const url = qs('/Reportes/TopPersonasData', {
            fechaDesde: document.getElementById('tDesde').value,
            fechaHasta: document.getElementById('tHasta').value,
            top: document.getElementById('tTop').value
        });

        const res = await fetch(url);
        const json = await res.json();
        const labels = json.data.map(x => x.nombre);
        const prestamos = json.data.map(x => x.prestamos);
        const reservas = json.data.map(x => x.reservas);

        document.getElementById('topTotal').textContent = `${json.totalSolicitudes} solicitudes`;
        document.getElementById('tablaTopPersonas').innerHTML = json.data.map(x => `
            <tr>
                <td>${x.nombre}</td>
                <td><span class="fw-semibold" style="color:#0f172a;">${x.total}</span></td>
            </tr>
        `).join('');

        const ctx = document.getElementById('topPersonasChart');
        if (topChart) topChart.destroy();

        topChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels,
                datasets: [
                    {
                        label: 'Préstamos',
                        data: prestamos,
                        backgroundColor: '#0369a1',
                        borderRadius: 8,
                        maxBarThickness: 28
                    },
                    {
                        label: 'Reservas',
                        data: reservas,
                        backgroundColor: '#38bdf8',
                        borderRadius: 8,
                        maxBarThickness: 28
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'top' }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { precision: 0 }
                    }
                }
            }
        });
    }

    function exportarTopPersonasPdf() {
        const url = qs('/Reportes/ExportarTopPersonasPdf', {
            fechaDesde: document.getElementById('tDesde').value,
            fechaHasta: document.getElementById('tHasta').value,
            top: document.getElementById('tTop').value
        });

        window.location.href = url;
    }

    document.addEventListener('DOMContentLoaded', cargarTopPersonas);
</script>
}
